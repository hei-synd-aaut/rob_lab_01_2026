    {
        "id": "1a7f0d849e7e154d",
        "type": "function",
        "z": "2acbf28b7034c4f3",
        "name": "Select how to display value",
        "func": "var getNumber = 1;\n\n// We create a ui_update object\nmsg.ui_update = {};\n// Add : to your label\nmsg.ui_update.label = env.get(\"setLabel\") + \" :\";\n\nmsg.ui_update.color = env.get(\"setColor\");\nmsg.ui_update.fontSize  = env.get(\"setFontSize\");\n\n// Convert multiplication factor from text to number\ngetNumber = Number(env.get(\"setMultiFactor\"));\n\nmsg.payload = msg.payload * getNumber;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 140,
        "wires": [
