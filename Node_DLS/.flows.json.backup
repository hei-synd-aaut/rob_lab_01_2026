        "name": "Build camera offset xy",
        "func": "var newMsg = {};\n\nnewMsg.payload = {\n    \"type\":\"ardouble\",\n    \"value\":[flow.get(\"Camera_Offset_Y\"),flow.get(\"Camera_Offset_X\"),0]\n}  \n\n\nreturn newMsg;",
