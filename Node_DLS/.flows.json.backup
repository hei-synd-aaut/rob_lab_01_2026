        "g": "0bdb5ec762c4f53c",
        "name": "M_MoveLinear",
        "func": "var newMsg = {};\n\nflow.get('rTargetPosition_x')\nflow.get('rTargetPosition_y')\nflow.get('rTargetPosition_z')\nflow.get('rTargetVelocity')\nflow.get('rTargetAcceleration')\n\nnewMsg.payload = {\n    type: \"object\",\n    value: {\n        \"TargetPosition_x\": flow.get('rTargetPosition_x'),\n        \"TargetPosition_y\": flow.get('rTargetPosition_y'),\n        \"TargetPosition_z\": flow.get('rTargetPosition_z'),\n        \"TargetVelocity\": flow.get('rTargetVelocity'),\n        \"TargetAcceleration\": flow.get('rTargetAcceleration'),\n    }\n}\nreturn newMsg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
