        "name": "Get PCS positions",
        "func": "var msg_x_pos = {payload: Math.round(msg.payload.pos[0] * 100) / 100};\nvar msg_y_pos = {payload: Math.round(msg.payload.pos[1] * 100) / 100};\nvar msg_z_pos = {payload: Math.round(msg.payload.pos[2] * 100) / 100};\n\nreturn [msg_x_pos,\n        msg_y_pos,\n        msg_z_pos];",
